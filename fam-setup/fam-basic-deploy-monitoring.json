{
    "policies": [
        {
            "name": "fam-basic-deploy-monitoring",
            "description": "Monitors deployments for changes to critical files such as /etc/passwd. Detects modifications at deployment time which may indicate image tampering or unauthorized changes to base images.",
            "rationale": "Modifications to system files like /etc/passwd during deployment can indicate that an image was tampered with or that there is a security misconfiguration. Monitoring for such occurrences reduces the risk of privilege escalation and persistent threats entering production.",
            "remediation": "Review the affected deployment and container image for unauthorized or unexpected changes to system files. Rebuild the image from a trusted source if necessary, and investigate any deployment pipelines or automation that could have introduced the modification.",
            "disabled": false,
            "categories": [
                "Anomalous Activity"
            ],
            "lifecycleStages": [
                "RUNTIME"
            ],
            "eventSource": "DEPLOYMENT_EVENT",
            "exclusions": [],
            "scope": [],
            "severity": "LOW_SEVERITY",
            "enforcementActions": [],
            "notifiers": [],
            "SORTName": "",
            "SORTLifecycleStage": "",
            "SORTEnforcement": false,
            "policyVersion": "1.1",
            "policySections": [
                {
                    "sectionName": "Rule 1",
                    "policyGroups": [
                        {
                            "fieldName": "Effective Path",
                            "booleanOperator": "OR",
                            "negate": false,
                            "values": [
